<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.grinch.browser</string>
    <key>CFBundleName</key>
    <string>Grinch</string>
    <key>CFBundleExecutable</key>
    <string>Grinch</string>
    <key>CFBundleIconFile</key>
    <string>grinch.icns</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <!-- CFBundleShortVersionString is rewritten from Cargo.toml at build
         time by the Makefile (PlistBuddy on $(BUNDLE)/Info.plist). The
         source value below is a placeholder; the value in any built or
         shipped bundle is the Cargo.toml version. Don't edit by hand. -->
    <key>CFBundleShortVersionString</key>
    <string>0.0.0-DEV</string>
    <key>CFBundleVersion</key>
    <string>2</string>
    <!-- Minimum macOS for the released universal binary. Mirrored in
         the README's Install section. -->
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>

    <!-- Required for macOS to include this app in the default browser list -->
    <key>NSUserActivityTypes</key>
    <array>
        <string>NSUserActivityTypeBrowsingWeb</string>
    </array>

    <!-- Declares Grinch as an eligible host for ASWebAuthenticationSession
         requests. Without this, macOS falls back to Safari for SSO/OAuth
         popups (Slack login, Claude Desktop login, many corporate auth
         flows) even when Grinch is the user's default browser — those
         requests don't go through the regular http handler chain, they
         go through a separate session manager that only consults apps
         declaring this capability. The session handler in
         session_handler.rs forwards each request URL through the same
         engine.resolve() that handles regular clicks, so SSO popups
         open in whatever browser the user's rules pick.

         EphemeralBrowserSessionIsSupported is intentionally absent.
         Apple's contract for ephemeral sessions is "no cookies, no
         storage, no profile state shared with the rest of the user's
         browsing" — and we can't honour that, since we forward the
         URL to the user's regular browser tab which inherits whatever
         cookies and profile are already in scope. Advertising the
         capability would mislead apps requesting `shouldUseEphemeral
         Session`; better to let them detect the missing key and fall
         back to a non-ephemeral flow themselves. -->
    <key>ASWebAuthenticationSessionWebBrowserSupportCapabilities</key>
    <dict>
        <key>IsSupported</key>
        <true/>
        <!-- CallbackURLMatchingIsSupported: declares that we will deliver
             matched callback URLs back through ASWebAuthenticationSession's
             `completeWithCallbackURL:` API. Some auth clients (e.g. Slack)
             gate SSO routing on this capability — without it, those clients
             skip Grinch and fall back to the system default browser even
             when we're the user's chosen handler.

             Best-effort scope: Grinch CAN complete callbacks that re-enter
             our URL handler (custom-scheme callbacks like
             `slack://oauth-callback?token=…`), but it CANNOT observe
             navigations inside the concrete browser we forward the auth
             URL to (because we hand the URL off and disappear from the
             flow). Matches Finicky PR #524's stance — see the long
             comment in `session_handler.rs::try_complete_callback`. -->
        <key>CallbackURLMatchingIsSupported</key>
        <true/>
    </dict>

    <!-- Schemes Grinch claims via LaunchServices. The engine routes anything
         that arrives at application:openURLs: through resolve() regardless
         of scheme, so adding entries here just lets the OS deliver them.
         http/https/mailto are the core set; tel/webcal/feed extend
         coverage at zero engine cost; `grinch` is the scripting hook for
         `open grinch:<inner-url>` (see handle_url for the unwrap). -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>CFBundleURLName</key>
            <string>Web URL</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>http</string>
                <string>https</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>CFBundleURLName</key>
            <string>Mail</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>mailto</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>CFBundleURLName</key>
            <string>Telephone</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>tel</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>CFBundleURLName</key>
            <string>Calendar Subscription</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>webcal</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>CFBundleURLName</key>
            <string>Feed</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>feed</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>CFBundleURLName</key>
            <string>Grinch routing scheme</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>grinch</string>
            </array>
        </dict>
    </array>

    <!-- Required for Grinch to appear in System Settings → Default web
         browser. macOS gates the picker on the com.apple.default-app.web-browser
         UTI, which is claimed via CFBundleDocumentTypes / public.html.
         Grinch routes file URLs through resolve() the same as http URLs;
         see application:openURLs: in the AppDelegate. -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>HTML Document</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Default</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.html</string>
                <string>public.xhtml</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
