#!/bin/bash
# Pre-commit hook: enforce `cargo fmt` so CI's `cargo fmt --all -- --check`
# never blocks a push. Runs in dry-run mode (--check); does NOT auto-edit
# the working tree. Skip with `git commit --no-verify` if needed (don't).
#
# Activate per-clone with one command:
#   git config core.hooksPath .githooks
# (CONTRIBUTING.md spells this out.)

set -euo pipefail

# Only run when there's at least one staged Rust file. Lets non-Rust commits
# (docs, workflows, examples) skip the cargo invocation overhead.
if ! git diff --cached --name-only --diff-filter=ACM | grep -q '\.rs$'; then
    exit 0
fi

if ! command -v cargo >/dev/null 2>&1; then
    echo "pre-commit: cargo not in PATH; skipping fmt check" >&2
    exit 0
fi

if ! cargo fmt --all -- --check; then
    echo "" >&2
    echo "pre-commit: rustfmt would reformat one or more files." >&2
    echo "Run 'cargo fmt --all', re-stage, and commit again." >&2
    exit 1
fi
